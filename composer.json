{
    "name": "chwnam/hime-nihongo-kanji-plugin",
    "description": "한자 쓰기 인쇄물 관리를 지원합니다.",
    "homepage": "https://github.com/chwnam/hime-nihongo-kanji-plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "HimeNihongo\\KanjiPlugin\\": "inc/"
        },
        "files": [
            "inc/facades.php",
            "inc/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "HimeNihongo\\KanjiPlugin\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "changwoo",
            "homepage": "https://blog.changwoo.pe.kr",
            "email": "ep6tri@hotmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "bojaghi/continy": "^1.2",
        "bojaghi/custom-tables": "^1.0",
        "bojaghi/admin-menus": "^1.0",
        "bojaghi/template": "^1.0",
        "bojaghi/admin-ajax": "^1.0",
        "bojaghi/clean-pages": "^1.1",
        "bojaghi/wp-tests": "^1.1"
    },
    "require-dev": {
        "bojaghi/vite-scripts": "^1.2",
        "phpunit/phpunit": "^9",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "scripts": {
        "wp-tests": [
            "@wp-tests:setenv",
            "vendor/bin/phpunit"
        ],
        "wp-tests:clean": [
            "@wp-tests:setenv",
            "rm -rf $WP_CORE_DIR $WP_TESTS_DIR"
        ],
        "wp-tests:env": [
            "@wp-tests:setenv",
            "vendor/bin/wp-tests -d"
        ],
        "wp-tests:setenv": [
            "@putenv WP_CORE_DIR=./tests/wp-test-core",
            "@putenv WP_TESTS_DIR=./tests/wp-test-lib",
            "@putenv WP_TESTS_PHPUNIT_POLYFILLS_PATH=./vendor/yoast/phpunit-polyfills",
            "@putenv DB_HOST=localhost",
            "@putenv DB_USER=wordpress_tests",
            "@putenv DB_PASS=wordpress_tests",
            "@putenv DB_NAME=wordpress_tests"
        ],
        "wp-tests:setup": [
            "@wp-tests:setenv",
            "@wp-tests:clean",
            "bin/install-wp-tests.sh $DB_NAME $DB_USER $DB_PASS $DB_HOST latest"
        ]
    }
}
