{
  "name": "chwnam/hime-nihongo-kanji-plugin",
  "description": "한자 쓰기 인쇄물 관리를 지원합니다.",
  "homepage": "https://github.com/chwnam/hime-nihongo-kanji-plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "autoload": {
    "psr-4": {
      "HimeNihongo\\KanjiPlugin\\": "inc/"
    },
    "files": [
      "inc/facades.php",
      "inc/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "HimeNihongo\\KanjiPlugin\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "changwoo",
      "homepage": "https://blog.changwoo.pe.kr",
      "email": "ep6tri@hotmail.com"
    }
  ],
  "require": {
    "php": ">=8.3",
    "bojaghi/continy": "^1.2",
    "bojaghi/custom-tables": "^1.0",
    "bojaghi/admin-menus": "^1.0",
    "bojaghi/template": "^1.0",
    "bojaghi/admin-ajax": "^1.0",
    "bojaghi/clean-pages": "^1.1"
  },
  "require-dev": {
    "bojaghi/vite-scripts": "^1.2"
  },
  "scripts": {
  }
}
